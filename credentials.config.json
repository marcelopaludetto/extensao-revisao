{
  "credentials": [
    {
      "id": "github",
      "storageKey": "aluraRevisorGithubToken",
      "type": "string",
      "label": "GitHub Personal Access Token",
      "platforms": ["api.github.com"],
      "httpHeader": { "name": "Authorization", "format": "Bearer {token}" },
      "required": true
    },
    {
      "id": "uploader",
      "storageKey": "aluraRevisorUploaderToken",
      "type": "string",
      "label": "Token video-uploader",
      "platforms": ["video-uploader.alura.com.br"],
      "httpHeader": { "name": "X-API-TOKEN", "format": "{token}" },
      "required": true
    },
    {
      "id": "aws",
      "storageKey": "aluraRevisorAwsCreds",
      "type": "object",
      "label": "AWS IAM Credentials (Bedrock)",
      "platforms": ["bedrock-runtime.amazonaws.com"],
      "fields": ["accessKeyId", "secretAccessKey", "region"],
      "authType": "sigv4",
      "required": true
    },
    {
      "id": "dropbox",
      "storageKeys": {
        "token": "aluraRevisorDropboxToken",
        "refreshToken": "aluraRevisorDropboxRefreshToken",
        "expiry": "aluraRevisorDropboxTokenExpiry",
        "clientId": "aluraRevisorDropboxClientId"
      },
      "type": "oauth2",
      "label": "Dropbox OAuth",
      "platforms": ["dropboxapi.com", "content.dropboxapi.com"],
      "httpHeader": { "name": "Authorization", "format": "Bearer {token}" },
      "autoRefresh": true,
      "tokenEndpoint": "https://api.dropboxapi.com/oauth2/token",
      "required": false
    }
  ]
}
