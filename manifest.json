{
  "manifest_version": 3,
  "name": "Start facilitadora de revisão",
  "version": "5.0",
  "update_url": "https://hub-producao-conteudo.vercel.app/update.xml",
  "description": "Deus existe e é brasileiro, mas não é o Bolsonaro. Ele é a Start Revisão!  (Escrito por IA)",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "downloads", "identity", "tabs"],
  "host_permissions": ["https://cursos.alura.com.br/*", "https://*/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Alura Revisor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }

  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["report.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://cursos.alura.com.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://cursos.alura.com.br/*"],
      "js": ["content-panel.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.dropbox.com/*"],
      "js": ["content-dropbox.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://guia.alura.dev/status/*"],
      "js": ["content-guia.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg"],
      "matches": ["https://cursos.alura.com.br/*", "https://www.dropbox.com/*"]
    },
    {
      "resources": ["popup.html", "popup.js"],
      "matches": ["https://cursos.alura.com.br/*", "https://guia.alura.dev/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "revisor-conteudo@alura.com.br",
      "strict_min_version": "121.0"
    }
  }
}
